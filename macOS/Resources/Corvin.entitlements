<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  No App Sandbox: Corvin ships via Developer ID + notarization, not the Mac App
	  Store. Its core features — global fn hotkey (CGEventTap), text insertion via
	  synthetic Cmd+V (CGEvent.post), and TCC reset via tccutil — are all forbidden
	  under App Sandbox. Sandbox is only required for the App Store.

	  Hardened Runtime IS enabled (codesign --options runtime), required for
	  notarization. Under Hardened Runtime the microphone is gated by an entitlement
	  even WITHOUT the sandbox: without com.apple.security.device.audio-input the
	  system blocks capture and AVCaptureDevice.requestAccess returns false with no
	  consent prompt. NSMicrophoneUsageDescription alone is not sufficient here.
	-->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
