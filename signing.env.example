# Local signing / Apple account configuration.
#
# Copy this file to `signing.env` (which is gitignored) and fill in your values.
# These identifiers stay out of the repository.
#
# Source it before building or generating the Xcode project so the values reach
# build-dmg.sh, xcodegen (${DEVELOPMENT_TEAM} expansion), and fastlane:
#
#   source signing.env
#
# Developer ID distribution (DMG):
export DEVELOPMENT_TEAM="YOUR_APPLE_TEAM_ID"
export SIGN_IDENTITY="Developer ID Application: Your Name (YOUR_APPLE_TEAM_ID)"

# App Store Connect API (only for TestFlight / App Store via fastlane or
# scripts/deploy-testflight.sh). The private key (.p8) lives outside the repo at
# ~/private_keys/AuthKey_<ASC_KEY_ID>.p8 and is never committed.
export ASC_KEY_ID="YOUR_ASC_KEY_ID"
export ASC_ISSUER_ID="YOUR_ASC_ISSUER_ID"
export ASC_APPLE_ID="YOUR_APP_STORE_APP_ID"
